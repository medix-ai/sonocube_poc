{
  "model_name": "lv_seg_ef",
  "model_version": "v0.1",
  "description": "Left Ventricle Segmentation and Ejection Fraction Estimation Model",
  
  "input": {
    "size": [224, 224],
    "channels": 1,
    "dtype": "float32",
    "normalize": {
      "mean": [0.5],
      "std": [0.5]
    }
  },
  
  "output": {
    "keys": ["lv_masks", "ef", "ed_frame_idx", "es_frame_idx"],
    "lv_masks": {
      "shape": ["T", "H", "W"],
      "dtype": "uint8",
      "threshold": 0.5
    },
    "ef": {
      "range": [0, 100],
      "unit": "percent"
    }
  },
  
  "preprocessing": {
    "resize_method": "bilinear",
    "normalize": true
  },
  
  "postprocessing": {
    "resize_to_original": true,
    "calculate_volumes": true,
    "pixel_to_ml_ratio": 0.01
  },
  
  "model_files": {
    "onnx": "lv_seg_ef_v0.1.onnx",
    "pytorch": "lv_seg_ef_v0.1.pt"
  }
}

